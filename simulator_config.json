{
  "mongodb": {
    "server_api_version": "1"
  },
  "simulation": {
    "duration_seconds": 90,
    "min_query_duration_ms": 8000,
    "sleep_range_ms": [
      2500,
      12000
    ],
    "max_workers": 5
  },
  "apps": [
    {
      "name": "orders-api",
      "enabled": true,
      "comment": "Traffic generated by orders-api",
      "queries": [
        {
          "database": "sample_mflix",
          "collection": "movies",
          "type": "find",
          "filter": {
            "year": {
              "$gte": 2010
            },
            "imdb.rating": {
              "$gte": 7
            }
          },
          "projection": {
            "title": 1,
            "year": 1,
            "imdb.rating": 1,
            "_id": 0
          },
          "limit": 8
        },
        {
          "database": "sample_mflix",
          "collection": "movies",
          "type": "aggregate",
          "pipeline": [
            {
              "$match": {
                "year": {
                  "$gte": 2000
                }
              }
            },
            {
              "$group": {
                "_id": "$year",
                "count": {
                  "$sum": 1
                }
              }
            },
            {
              "$sort": {
                "count": -1
              }
            },
            {
              "$limit": 5
            }
          ]
        }
      ]
    },
    {
      "name": "customer-portal",
      "enabled": true,
      "comment": "Traffic generated by customer-portal",
      "queries": [
        {
          "database": "sample_airbnb",
          "collection": "listingsAndReviews",
          "type": "find",
          "filter": {
            "bedrooms": {
              "$lte": 2
            },
            "address.market": "Sydney"
          },
          "projection": {
            "name": 1,
            "bedrooms": 1,
            "price": 1,
            "address.market": 1,
            "_id": 0
          },
          "limit": 6
        },
        {
          "database": "sample_airbnb",
          "collection": "listingsAndReviews",
          "type": "count_documents",
          "filter": {
            "amenities": "Wifi"
          }
        }
      ]
    },
    {
      "name": "analytics-worker",
      "enabled": true,
      "comment": "Traffic generated by analytics-worker",
      "queries": [
        {
          "database": "sample_analytics",
          "collection": "accounts",
          "type": "find",
          "filter": {
            "products": "CurrencyService"
          },
          "projection": {
            "account_id": 1,
            "name": 1,
            "products": 1,
            "_id": 0
          },
          "limit": 10
        },
        {
          "database": "sample_analytics",
          "collection": "accounts",
          "type": "distinct",
          "key": "products"
        }
      ]
    }
  ]
}
